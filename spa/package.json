{
  "name": "kamscore-spa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run format && npm run lint && vue-tsc --noEmit && vite build",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "lint:check": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mdi/font": "^7.4.0",
    "axios": "^1.7.0",
    "pinia": "^3.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "vuetify": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.2",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.1.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.2.0"
  }
}
