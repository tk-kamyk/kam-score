{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "*.{css,js,svg,png,jpg,jpeg,gif,ico,webp,woff,woff2,webmanifest}"
    ]
  },
  "routes": [
    {
      "route": "/service-worker.js",
      "headers": {
        "Cache-Control": "no-cache"
      }
    }
  ]
}
